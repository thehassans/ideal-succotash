# Server Configuration
NODE_ENV=production
PORT=3001

# Custom URL for Plesk Deployment
APP_URL=https://your-domain.com

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/explore_holidays
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_pg_password
PGDATABASE=explore_holidays
PGSSLMODE=disable

# SEO Configuration
SITE_NAME=Explore Holidays
SITE_DESCRIPTION=Premium Travel Booking Platform - Flights, Holidays, Visas from Bangladesh
SITE_KEYWORDS=travel,holidays,flights,visas,bangladesh,booking,packages,tours

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
